{
  "name": "ama-desktop",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "AMA desktop app (Electron) — hero console + admin control panel. Brain: Hermes → Gemini. Voice: Gemini TTS.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "electron": "ELECTRON_DEV=1 electron electron/main.cjs",
    "electron:dev": "concurrently -k \"npm run dev\" \"wait-on http://localhost:1420 && ELECTRON_DEV=1 electron electron/main.cjs\""
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "@ricky0123/vad-web": "^0.0.30",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^10.0.3",
    "electron": "^43.0.0",
    "typescript": "^5.6.3",
    "vite": "^6.0.5",
    "vite-plugin-static-copy": "^4.1.1",
    "wait-on": "^9.0.10"
  }
}
