# AMA — secrets template.
# Copy to .env and fill in. NEVER commit the real .env.
# Note: Hermes itself stores secrets in ~/.hermes/.env (set via `hermes config set`);
# this file is for AMA's own custom layer (e.g. the dashboard) and local tooling.

# --- Brain / model provider ---
# Default brain is LOCAL Ollama — no API key or secret needed.
# Ollama runs at http://localhost:11434 by default.
# OLLAMA_BASE_URL=http://localhost:11434
#
# Optional upgrade only: if you later swap the brain to a cloud API, add its key:
# ANTHROPIC_API_KEY=

# --- Remote channel (Phase 3) — pluggable adapter, TBD (NOT Telegram) ---
# Candidates: Signal / our-own-UI-over-Tailscale / Discord. Fill in once chosen.
# Allowlist = only you.
# REMOTE_CHANNEL=
# REMOTE_ALLOWED_USER_ID=

# --- Dashboard (Phase 4) ---
# Port the local permissions dashboard listens on.
# DASHBOARD_PORT=4040
